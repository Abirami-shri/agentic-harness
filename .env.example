# ---------------------------------------------------------------------------
# Azure AI Foundry — the agent's reasoning runs here.
# ---------------------------------------------------------------------------
# Project endpoint (data-plane URL of your provisioned Foundry project):
AZURE_AI_PROJECT_ENDPOINT=https://mcp-agentic-harness.services.ai.azure.com/api/projects/proj-default
# Model deployment the agent uses for reasoning:
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Auth — choose ONE:
#   (a) Entra ID (recommended): run `az login`; nothing to set here.
#   (b) API key:
# AZURE_AI_PROJECT_API_KEY=<your-foundry-project-key>

# Optional: name registered for the agent (default: box-skills-agent)
# FOUNDRY_AGENT_NAME=box-skills-agent

# ---------------------------------------------------------------------------
# Box connector — used by the three skills.
# ---------------------------------------------------------------------------
# Simplest: a developer/bearer token.
BOX_API_TOKEN=

# Or Client Credentials Grant (CCG) — leave BOX_API_TOKEN blank and set:
# BOX_CLIENT_ID=
# BOX_CLIENT_SECRET=
# BOX_ENTERPRISE_ID=        # for app/enterprise auth
# BOX_USER_ID=              # for as-user auth (alternative to enterprise)
